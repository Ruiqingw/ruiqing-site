---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPhotography = await getCollection('photography');

const allImages = allPhotography.flatMap((project) => {
  const featured = project.data.featured ?? [];
  return featured.map((src: string) => ({
    src,
    alt: project.data.title,
  }));
});
---

<BaseLayout title="Ruiqing" description="Photography portfolio and personal blog by Ruiqing">
  <section class="gallery-section">
    <div class="gallery-grid" id="gallery-grid">
      {allImages.map((img) => (
        <div class="gallery-item" data-title={img.alt}>
          <img
            src={img.src}
            alt={img.alt}
            loading="lazy"
          />
          <span class="gallery-label">{img.alt}</span>
        </div>
      ))}
    </div>
  </section>

  <div class="lightbox" id="lightbox" aria-hidden="true">
    <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
    <button class="lightbox-close" id="lightbox-close" aria-label="关闭">×</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
  </div>
</BaseLayout>

<script>
  const grid = document.getElementById('gallery-grid')!;

  // Shuffle
  const items = [...grid.children] as Element[];
  for (let i = items.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [items[i], items[j]] = [items[j], items[i]];
  }
  items.forEach(item => grid.appendChild(item));

  // Reveal grid after first 6 images load
  const THRESHOLD = 6;
  const TIMEOUT = 2000;
  const imgs = [...grid.querySelectorAll('img')] as HTMLImageElement[];
  let shown = false;
  let loadedCount = 0;

  function showGrid() {
    if (shown) return;
    shown = true;
    grid.classList.add('visible');
  }

  const fallback = setTimeout(showGrid, TIMEOUT);

  function onLoad() {
    loadedCount++;
    if (loadedCount >= Math.min(THRESHOLD, imgs.length)) {
      clearTimeout(fallback);
      showGrid();
    }
  }

  imgs.forEach(img => {
    if (img.complete) onLoad();
    else {
      img.addEventListener('load', onLoad);
      img.addEventListener('error', onLoad);
    }
  });

  // Lightbox
  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxClose = document.getElementById('lightbox-close')!;
  const lightboxBackdrop = document.getElementById('lightbox-backdrop')!;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    lightboxImg.src = '';
  }

  grid.addEventListener('click', (e) => {
    const item = (e.target as Element).closest('.gallery-item') as HTMLElement | null;
    if (item) {
      const img = item.querySelector('img') as HTMLImageElement | null;
      if (img) openLightbox(img.src, img.alt);
    }
  });

  lightboxClose.addEventListener('click', closeLightbox);
  lightboxBackdrop.addEventListener('click', closeLightbox);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>

<style>
  .gallery-section {
    padding: 0.5rem 6vw 6rem;
  }

  .gallery-grid {
    columns: 3;
    column-gap: 2rem;
    opacity: 0;
    transition: opacity 0.8s ease;
  }

  .gallery-grid.visible {
    opacity: 1;
  }

  .gallery-item {
    break-inside: avoid;
    margin-bottom: 2rem;
    cursor: pointer;
    position: relative;
    overflow: hidden;
  }

  .gallery-item img {
    width: 100%;
    display: block;
    transition: transform 0.5s ease, opacity 0.3s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.025);
    opacity: 0.92;
  }

  .gallery-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem 1rem 0.75rem;
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: #fff;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.35));
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }

  .gallery-item:hover .gallery-label {
    opacity: 1;
    transform: translateY(0);
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .lightbox[aria-hidden="false"] {
    pointer-events: auto;
    opacity: 1;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.96);
  }

  .lightbox-img {
    position: relative;
    z-index: 1;
    max-width: 82vw;
    max-height: 88vh;
    object-fit: contain;
    display: block;
    box-shadow: 0 8px 60px rgba(0, 0, 0, 0.12);
  }

  .lightbox-close {
    position: absolute;
    top: 1.5rem;
    right: 2rem;
    z-index: 2;
    background: none;
    border: none;
    color: #1a1a1a;
    font-size: 1.75rem;
    font-weight: 300;
    line-height: 1;
    cursor: pointer;
    opacity: 0.5;
    padding: 0.25rem 0.5rem;
    transition: opacity 0.2s ease;
    font-family: var(--font-heading);
  }

  .lightbox-close:hover {
    opacity: 1;
  }

  @media (max-width: 1024px) {
    .gallery-section {
      padding: 0.5rem 4vw 5rem;
    }
    .gallery-grid {
      column-gap: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .gallery-grid {
      columns: 2;
      column-gap: 1rem;
    }
    .gallery-item {
      margin-bottom: 1rem;
    }
  }

  @media (max-width: 480px) {
    .gallery-section {
      padding: 0.5rem 1rem 3rem;
    }
    .gallery-grid {
      columns: 1;
    }
  }
</style>
