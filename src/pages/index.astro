---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPhotography = await getCollection('photography');

const allImages = allPhotography.flatMap((project) => {
  const featured = project.data.featured ?? [];
  return featured.map((src: string) => ({
    src,
    alt: project.data.title,
  }));
});
---

<BaseLayout title="Ruiqing" description="Photography portfolio and personal blog by Ruiqing">
  <section class="gallery-section">
    <div class="gallery-grid" id="gallery-grid">
      {allImages.map((img) => (
        <div class="gallery-item">
          <img
            src={img.src}
            alt={img.alt}
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </section>

  <div class="lightbox" id="lightbox" aria-hidden="true">
    <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
    <button class="lightbox-close" id="lightbox-close" aria-label="关闭">×</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
  </div>
</BaseLayout>

<script>
  // Shuffle gallery items on every page load
  const grid = document.getElementById('gallery-grid')!;
  const items = [...grid.children] as Element[];
  for (let i = items.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [items[i], items[j]] = [items[j], items[i]];
  }
  items.forEach(item => grid.appendChild(item));

  // Lightbox
  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxClose = document.getElementById('lightbox-close')!;
  const lightboxBackdrop = document.getElementById('lightbox-backdrop')!;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    lightboxImg.src = '';
  }

  grid.addEventListener('click', (e) => {
    const img = (e.target as Element).closest('.gallery-item img') as HTMLImageElement | null;
    if (img) openLightbox(img.src, img.alt);
  });

  lightboxClose.addEventListener('click', closeLightbox);
  lightboxBackdrop.addEventListener('click', closeLightbox);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>

<style>
  .gallery-section {
    padding: 1rem 3rem 4rem;
  }

  .gallery-grid {
    columns: 3;
    column-gap: 1.5rem;
  }

  .gallery-item {
    break-inside: avoid;
    margin-bottom: 1.5rem;
    cursor: pointer;
    overflow: hidden;
  }

  .gallery-item img {
    width: 100%;
    display: block;
    transition: opacity 0.25s ease;
  }

  .gallery-item:hover img {
    opacity: 0.88;
  }

  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .lightbox[aria-hidden="false"] {
    pointer-events: auto;
    opacity: 1;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.92);
  }

  .lightbox-img {
    position: relative;
    z-index: 1;
    max-width: 90vw;
    max-height: 90vh;
    object-fit: contain;
    display: block;
  }

  .lightbox-close {
    position: absolute;
    top: 1.25rem;
    right: 1.5rem;
    z-index: 2;
    background: none;
    border: none;
    color: #333;
    font-size: 2rem;
    line-height: 1;
    cursor: pointer;
    opacity: 0.8;
    padding: 0.25rem 0.5rem;
    transition: opacity 0.15s ease;
  }

  .lightbox-close:hover {
    opacity: 1;
  }

  @media (max-width: 900px) {
    .gallery-grid {
      columns: 2;
    }
  }

  @media (max-width: 540px) {
    .gallery-section {
      padding: 0.75rem 1rem 3rem;
    }

    .gallery-grid {
      columns: 1;
    }
  }
</style>
