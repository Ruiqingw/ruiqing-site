---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPhotography = await getCollection('photography');
const sorted = allPhotography.sort((a, b) => {
  const orderA = a.data.order ?? 999;
  const orderB = b.data.order ?? 999;
  if (orderA !== orderB) return orderA - orderB;
  return new Date(b.data.date).getTime() - new Date(a.data.date).getTime();
});
---

<BaseLayout title="Ruiqing" description="Photography portfolio and personal blog by Ruiqing">
  <section class="hero">
    <p class="hero-subtitle">Photography & Thoughts</p>
  </section>

  <section class="gallery-section">
    <div class="gallery-scroll">
      {sorted.map((project) => (
        <a href={`/photography/${project.id}`} class="gallery-item">
          <div class="gallery-image-wrapper">
            <img
              src={project.data.cover}
              alt={project.data.title}
              loading="lazy"
            />
          </div>
          <span class="gallery-title">{project.data.title}</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    text-align: center;
    padding: 1.5rem 2rem 2rem;
  }

  .hero-subtitle {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
    font-weight: 300;
  }

  .gallery-section {
    padding: 0 2rem 4rem;
    overflow: hidden;
  }

  .gallery-scroll {
    display: flex;
    gap: 1.25rem;
    overflow-x: auto;
    padding-bottom: 1rem;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
  }

  .gallery-scroll::-webkit-scrollbar {
    height: 4px;
  }

  .gallery-scroll::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 2px;
  }

  .gallery-item {
    flex: 0 0 auto;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover {
    opacity: 1;
    transform: translateY(-4px);
  }

  .gallery-image-wrapper {
    width: 280px;
    height: 380px;
    overflow: hidden;
    background: #f5f5f5;
  }

  .gallery-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .gallery-item:hover .gallery-image-wrapper img {
    transform: scale(1.03);
  }

  .gallery-title {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    font-weight: 400;
  }

  @media (max-width: 768px) {
    .gallery-section {
      padding: 0 1.25rem 3rem;
    }

    .gallery-image-wrapper {
      width: 220px;
      height: 300px;
    }
  }
</style>
