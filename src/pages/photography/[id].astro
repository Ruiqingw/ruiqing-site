---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allPhotography = await getCollection('photography');
  return allPhotography.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const dateStr = new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// If body is empty, fall back to rendering from the images array
const hasBody = entry.body && entry.body.trim().length > 0;
const fallbackImages = (entry.data.images || []).filter((src: string) => src !== entry.data.cover);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="photo-detail">
    <header class="photo-header">
      <h2>{entry.data.title}</h2>
      <time>{dateStr}</time>
    </header>

    {entry.data.description && (
      <p class="photo-description">{entry.data.description}</p>
    )}

    <!-- Cover image always shown first -->
    <div class="photo-cover">
      <img src={entry.data.cover} alt={entry.data.title} loading="eager" />
    </div>

    {hasBody ? (
      <!-- Body: free mix of text and images written in Obsidian -->
      <div class="photo-body">
        <Content />
      </div>
    ) : (
      <!-- Fallback: render remaining images from frontmatter array -->
      <div class="photo-grid">
        {fallbackImages.map((src: string, i: number) => (
          <img src={src} alt={`${entry.data.title} - ${i + 1}`} loading="lazy" />
        ))}
      </div>
    )}

    <nav class="photo-back">
      <a href="/">&larr; Back to gallery</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .photo-detail {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
  }

  .photo-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .photo-header h2 {
    font-size: 1.25rem;
    margin-bottom: 0.5rem;
  }

  .photo-header time {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .photo-description {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    max-width: 600px;
    margin: 0 auto 2rem;
  }

  .photo-cover img {
    width: 100%;
    object-fit: contain;
    display: block;
  }

  /* Body area: text + images freely mixed */
  .photo-body {
    margin-top: 1.5rem;
    font-size: 0.95rem;
    line-height: 1.8;
  }

  /* Images inserted via markdown render full-width with spacing */
  .photo-body :global(img) {
    width: 100%;
    object-fit: contain;
    display: block;
    margin: 1.5rem 0;
  }

  /* Text paragraphs are centered and narrower for readability */
  .photo-body :global(p:not(:has(img))) {
    max-width: 600px;
    margin: 1rem auto;
    color: var(--color-text-secondary);
  }

  .photo-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .photo-grid img {
    width: 100%;
    object-fit: contain;
    display: block;
  }

  .photo-back {
    margin-top: 3rem;
    text-align: center;
  }

  .photo-back a {
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
  }
</style>
