---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allEssays = await getCollection('essays', ({ data }) => !data.draft);
const sorted = allEssays.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryLabels: Record<string, string> = {
  essay: 'Essay',
  'film-review': 'Film',
  'book-review': 'Book',
  thought: 'Thought',
  poem: 'Poem',
};

// Only show filter buttons for categories that actually exist
const existingCategories = [...new Set(
  sorted.map(p => p.data.category).filter(Boolean)
)] as string[];
---

<BaseLayout title="Essays" description="Random thoughts, film reviews, and book reviews">
  <section class="essay-list">
    <p class="section-subtitle">Thoughts, film reviews, book reviews, and other writings</p>

    {existingCategories.length > 1 && (
      <div class="filters" id="filters">
        {existingCategories.map((cat) => (
          <button class="filter-btn" data-filter={cat}>
            {categoryLabels[cat] || cat}
          </button>
        ))}
      </div>
    )}

    {sorted.length === 0 ? (
      <p class="empty-state">Coming soon...</p>
    ) : (
      <ul class="posts" id="posts">
        {sorted.map((post) => (
          <li data-category={post.data.category || ''}>
            <a href={`/essays/${post.id}`} class="post-link">
              <div class="post-meta">
                <time>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}</time>
                {post.data.category && (
                  <span class="category">{categoryLabels[post.data.category] || post.data.category}</span>
                )}
              </div>
              <h3>{post.data.title}</h3>
              {post.data.description && (
                <p class="post-desc">{post.data.description}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const buttons = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('#posts li');
    const selected = new Set();

    function applyFilter() {
      items.forEach((item) => {
        if (selected.size === 0) {
          item.style.display = '';
          return;
        }
        const cat = item.dataset.category;
        item.style.display = selected.has(cat) ? '' : 'none';
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        if (selected.has(filter)) {
          selected.delete(filter);
          btn.classList.remove('active');
        } else {
          selected.add(filter);
          btn.classList.add('active');
        }
        applyFilter();
      });
    });
  });
</script>

<style>
  .essay-list {
    max-width: 720px;
    margin: 0 auto;
    padding: 1.5rem 2rem 4rem;
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 2rem;
  }

  .filters {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .filter-btn {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    background: none;
    border: 1px solid var(--color-border);
    padding: 0.25em 0.75em;
    border-radius: 3px;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .filter-btn:hover {
    color: var(--color-text);
    border-color: var(--color-text-secondary);
  }

  .filter-btn.active {
    color: var(--color-text);
    border-color: var(--color-text);
    background: var(--color-text);
    color: white;
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    padding: 4rem 0;
  }

  .posts {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .posts li {
    border-bottom: 1px solid var(--color-border);
  }

  .posts li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-link {
    display: block;
    padding: 1.5rem 0;
    transition: padding-left 0.2s ease;
  }

  .post-link:hover {
    padding-left: 0.5rem;
    opacity: 1;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .post-meta time {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    letter-spacing: 0.03em;
  }

  .category {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    padding: 0.1em 0.4em;
    border-radius: 3px;
  }

  .post-link h3 {
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0.01em;
    margin: 0.3rem 0 0.4rem;
    color: var(--color-text);
  }

  .post-desc {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
</style>
