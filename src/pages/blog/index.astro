---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Tech Blog" description="Technical blog posts about LLM, AI agents, and more">
  <section class="blog-list">
    <p class="section-subtitle">Notes on LLMs, agents, and things I'm learning</p>

    {sorted.length === 0 ? (
      <p class="empty-state">Coming soon...</p>
    ) : (
      <ul class="posts">
        {sorted.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="post-link">
              <time>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' })}</time>
              <h3>{post.data.title}</h3>
              {post.data.description && (
                <p class="post-desc">{post.data.description}</p>
              )}
              {post.data.tags && (
                <div class="post-tags">
                  {post.data.tags.map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .blog-list {
    max-width: 720px;
    margin: 0 auto;
    padding: 1.5rem 2rem 4rem;
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 3rem;
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    padding: 4rem 0;
  }

  .posts {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .posts li {
    border-bottom: 1px solid var(--color-border);
  }

  .posts li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-link {
    display: block;
    padding: 1.5rem 0;
    transition: padding-left 0.2s ease;
  }

  .post-link:hover {
    padding-left: 0.5rem;
    opacity: 1;
  }

  .post-link time {
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .post-link h3 {
    font-family: var(--font-heading);
    font-size:1.1rem;
    font-weight: 600;
    text-transform: none;
    letter-spacing: 0.01em;
    margin: 0.35rem 0 0.5rem;
    color: var(--color-text);
    line-height: 1.3;
  }

  .post-desc {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    background: #fafafa;
    padding: 0.2em 0.6em;
    border-radius: 2px;
    letter-spacing: 0.05em;
  }
</style>
