---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sorted = allPosts.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout title="Tech Blog" description="Technical blog posts about LLM, AI agents, and more">
  <section class="blog-list">
    <p class="section-subtitle">Notes on LLMs, agents, and things I'm learning</p>

    {sorted.length === 0 ? (
      <p class="empty-state">Coming soon...</p>
    ) : (
      <ul class="posts">
        {sorted.map((post) => (
          <li>
            <a href={`/blog/${post.id}`} class="post-link">
              <time>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', timeZone: 'UTC' })}</time>
              <span class="post-title">{post.data.title}</span>
              {post.data.tags && (
                <span class="post-tags">{post.data.tags.join(' · ')}</span>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>

<style>
  .blog-list {
    max-width: 760px;
    margin: 0 auto;
    padding: 1.5rem 2rem 4rem;
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    margin-bottom: 3rem;
  }

  .empty-state {
    text-align: center;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    padding: 4rem 0;
  }

  .posts {
    list-style: none;
    display: flex;
    flex-direction: column;
  }

  .posts li {
    border-bottom: 1px solid var(--color-border);
  }

  .posts li:first-child {
    border-top: 1px solid var(--color-border);
  }

  .post-link {
    display: grid;
    grid-template-columns: 7rem 1fr auto;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1rem 0;
    transition: opacity 0.15s ease;
  }

  .post-link:hover {
    opacity: 0.6;
  }

  .post-link time {
    font-size: 0.72rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.03em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .post-title {
    font-size: 0.95rem;
    font-weight: 500;
    font-family: var(--font-heading);
    letter-spacing: 0.01em;
    color: var(--color-text);
  }

  .post-tags {
    font-size: 0.65rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.03em;
    white-space: nowrap;
    text-align: right;
  }

  @media (max-width: 600px) {
    .post-link {
      grid-template-columns: 1fr;
      gap: 0.2rem;
      padding: 0.85rem 0;
    }

    .post-tags {
      text-align: left;
    }
  }
</style>
