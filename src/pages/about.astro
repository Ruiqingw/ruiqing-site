---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="About" description="About Ruiqing">
  <section class="about">
    <div class="about-content">
      <p>
        Hi, I'm Ruiqing — a photographer and developer exploring the intersection of
        visual storytelling and technology.
      </p>

      <p>
        This site is home to my photography work, random essays and reviews, and a
        technical blog where I document my journey learning about large language models
        and AI agents.
      </p>

      <div class="about-section">
        <h3>Photography</h3>
        <p>
          I capture moments that speak to me — street scenes, urban landscapes, and
          the quiet details of everyday life.
        </p>
      </div>

      <div class="about-section">
        <h3>Writing</h3>
        <p>
          Occasional thoughts on films, books, and whatever else occupies my mind.
          I also write technical posts about LLMs, reinforcement learning, and
          building AI agents.
        </p>
      </div>

      <div class="about-contact">
        <h3>Contact</h3>
        <p>
          <a href="mailto:ruiqingw2002@gmail.com">ruiqingw2002@gmail.com</a>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    max-width: 600px;
    margin: 0 auto;
    padding: 2rem;
  }

  .about-content p {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    text-align: center;
  }

  .about-section {
    margin-top: 2.5rem;
  }

  .about-section h3 {
    text-align: center;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
  }

  .about-contact {
    margin-top: 2.5rem;
    text-align: center;
  }

  .about-contact h3 {
    font-size: 0.85rem;
    letter-spacing: 0.1em;
    margin-bottom: 0.5rem;
  }

  .about-contact a {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
