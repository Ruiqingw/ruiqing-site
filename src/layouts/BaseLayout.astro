---
import '@/styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ruiqing',
  description = 'Photography, essays, and tech blog by Ruiqing',
} = Astro.props;

const pageTitle = title === 'Ruiqing' ? title : `${title} — Ruiqing`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=JetBrains+Mono:wght@400&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="site-name">RUIQING</a>
      <nav class="site-nav">
        <a href="/" class:list={[Astro.url.pathname === '/' && 'active']}>Photography</a>
        <a href="/blog" class:list={[Astro.url.pathname.startsWith('/blog') && 'active']}>Blog</a>
        <a href="/essays" class:list={[Astro.url.pathname.startsWith('/essays') && 'active']}>Essays</a>
        <a href="/about" class:list={[Astro.url.pathname === '/about' && 'active']}>About</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Ruiqing</p>
    </footer>
  </body>
</html>

<style>
  .site-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2.5rem 2rem 1rem;
    gap: 0.75rem;
  }

  .site-name {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 300;
    letter-spacing: 0.2em;
    color: var(--color-text);
  }

  .site-name:hover {
    opacity: 1;
  }

  .site-nav {
    display: flex;
    gap: 2rem;
  }

  .site-nav a {
    font-size: 0.85rem;
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    transition: color 0.2s ease;
  }

  .site-nav a:hover {
    color: var(--color-text);
    opacity: 1;
  }

  .site-nav a.active {
    color: var(--color-text);
  }

  main {
    min-height: calc(100vh - 200px);
  }

  .site-footer {
    text-align: center;
    padding: 3rem 2rem;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .site-header {
      padding: 1.5rem 1.25rem 0.75rem;
    }

    .site-name {
      font-size: 1.5rem;
    }

    .site-nav {
      gap: 1.25rem;
    }

    .site-nav a {
      font-size: 0.7rem;
    }
  }
</style>
