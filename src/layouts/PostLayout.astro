---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: string;
  tags?: string[];
  description?: string;
  category?: string;
  backLink: string;
  backText: string;
}

const { title, date, tags, description, category, backLink, backText } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="post-header">
      <h2>{title}</h2>
      <div class="post-meta">
        <time>{date}</time>
        {category && <span class="post-category">{category}</span>}
      </div>
      {tags && tags.length > 0 && (
        <div class="post-tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="post-body">
      <slot />
    </div>

    <nav class="post-back">
      <a href={backLink}>&larr; {backText}</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .post {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem;
  }

  .post-header {
    text-align: center;
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .post-header h2 {
    font-size: 1.4rem;
    text-transform: none;
    letter-spacing: 0.02em;
    font-weight: 400;
    margin-bottom: 0.75rem;
  }

  .post-meta {
    display: flex;
    justify-content: center;
    gap: 1rem;
    align-items: center;
  }

  .post-meta time {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }

  .post-category {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    padding: 0.15em 0.5em;
    border-radius: 3px;
  }

  .post-tags {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.7rem;
    color: var(--color-text-secondary);
    background: #f5f5f5;
    padding: 0.2em 0.6em;
    border-radius: 3px;
    letter-spacing: 0.03em;
  }

  .post-body {
    font-size: 1rem;
    line-height: 1.8;
  }

  .post-body :global(h1) {
    font-size: 1.3rem;
    text-transform: none;
    letter-spacing: 0.01em;
    font-weight: 600;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }

  .post-body :global(h2) {
    font-size: 1.15rem;
    text-transform: none;
    letter-spacing: 0.01em;
    font-weight: 600;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .post-body :global(h3) {
    font-size: 1rem;
    text-transform: none;
    letter-spacing: 0.01em;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .post-body :global(blockquote) {
    border-left: 2px solid var(--color-border);
    padding-left: 1.25rem;
    color: var(--color-text-secondary);
    margin: 1.5rem 0;
    font-style: italic;
  }

  .post-body :global(img) {
    border-radius: 4px;
    margin: 1.5rem 0;
  }

  .post-body :global(a) {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.5rem;
    margin-bottom: 1.2em;
  }

  .post-body :global(li) {
    margin-bottom: 0.3em;
  }

  /* Math display blocks */
  .post-body :global(.katex-display) {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.5rem 0;
    margin: 1.5rem 0;
    text-align: center;
  }

  .post-body :global(.katex-display > .katex) {
    text-align: center;
  }

  /* Tables */
  .post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .post-body :global(th),
  .post-body :global(td) {
    border: 1px solid var(--color-border);
    padding: 0.6rem 0.8rem;
    text-align: left;
    vertical-align: top;
  }

  .post-body :global(th) {
    font-weight: 600;
    background: #fafafa;
  }

  .post-body :global(tr:hover) {
    background: #fafafa;
  }

  .post-back {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .post-back a {
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
  }
</style>
